# Google Sheets
# Spreadsheet ID from the sheet URL: https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
SPREADSHEET_ID=

# Path to the Google service-account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Telegram
# Token from @BotFather
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to use the bot (get yours from @userinfobot)
ALLOWED_TELEGRAM_IDS=

# API
PORT=3000
# Shared secret the mobile app sends as "Authorization: Bearer <key>"
API_KEY=change-me-to-a-long-random-string

# Gemini (receipt scanning) — free key from https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional: override the model
# GEMINI_MODEL=gemini-2.0-flash
